{
  "openapi": "3.0.3",
  "info": {
    "title": "Ekadash API",
    "version": "1.1.0",
    "description": "API for Ekadash application"
  },
  "servers": [
    {
      "url": "/ekadash_api/v1",
      "description": "API base path"
    }
  ],
  "tags": [
    { "name": "Health", "description": "Health check" },
    { "name": "Auth", "description": "Authentication" },
    { "name": "User", "description": "User profile" },
    { "name": "Logs", "description": "Client logs" },
    { "name": "Ekadash", "description": "Ekadash calendar data" },
    { "name": "Ekadash Info", "description": "Ekadash information" },
    { "name": "City", "description": "City lookup" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns API status and current time",
        "security": [],
        "responses": {
          "200": {
            "description": "API is running",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/auth/signUp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign up",
        "description": "Register a new user. Returns user document or existing user if deviceId already exists.",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthSignUpBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User document",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "text/plain": { "schema": { "type": "string" } }
            }
          }
        }
      }
    },
    "/auth/signIn": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in",
        "description": "Authenticate by deviceId. Returns user document or null if not found.",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthSignInBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User document or null",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/User" },
                    { "type": "null" }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": { "schema": {} }
            }
          }
        }
      }
    },
    "/logs": {
      "post": {
        "tags": ["Logs"],
        "summary": "Submit logs",
        "description": "Send client logs to the server. Body: { logMessage: ... }.",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LogsBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logs accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LogsResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Invalid X-API-KEY" }
        }
      }
    },
    "/user": {
      "get": {
        "tags": ["User"],
        "summary": "Get current user",
        "description": "Returns the authenticated user profile (deviceId from Bearer token).",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "responses": {
          "200": {
            "description": "User document or null",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/User" },
                    { "type": "null" }
                  ]
                }
              }
            }
          },
          "401": { "description": "Authorization header missing" }
        }
      }
    },
    "/user/update": {
      "patch": {
        "tags": ["User"],
        "summary": "Update user",
        "description": "Update the authenticated user (deviceId from Bearer token). Body: partial user fields.",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "language": { "type": "string" },
                  "timezone": { "type": "string" },
                  "email": { "type": "string", "nullable": true },
                  "tg": { "type": "string", "nullable": true },
                  "daysRemindPush": { "type": "number" },
                  "notifiedToday": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mongoose updateOne result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpdateResult" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/ekadash/year": {
      "get": {
        "tags": ["Ekadash"],
        "summary": "Get by year",
        "description": "Get ekadash list for a year. Each item: id, date (YYYY-MM-DD), name, exit_time.",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "year", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "Year" }
        ],
        "responses": {
          "200": {
            "description": "List of ekadash items for the year",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashYearResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ekadash/month": {
      "get": {
        "tags": ["Ekadash"],
        "summary": "Get by month",
        "description": "Get raw ekadash documents for a month.",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "year", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "month", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "status and ekadashes array",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashMonthResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ekadash/day": {
      "get": {
        "tags": ["Ekadash"],
        "summary": "Get by day",
        "description": "Get single ekadash for a day with populated description_data (ekadash info).",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "year", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "month", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "day", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "status and ekadash object with description_data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashDayResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ekadash-info": {
      "get": {
        "tags": ["Ekadash Info"],
        "summary": "Get all",
        "description": "Get all ekadash info entries. Query: limit (optional, default 100, max 500).",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 }, "description": "Max items (max 500)" }
        ],
        "responses": {
          "200": {
            "description": "status and data array of ekadash info items",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashInfoListResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ekadash-info/search": {
      "get": {
        "tags": ["Ekadash Info"],
        "summary": "Search by name (query)",
        "description": "Get one ekadash info by name (case-insensitive). Query: name=...",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "name", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Name to search" }
        ],
        "responses": {
          "200": {
            "description": "status and data (single EkadashInfoItem)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashInfoOneResponse" }
              }
            }
          },
          "400": {
            "description": "Name is required",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": {
            "description": "Ekadashi info not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ekadash-info/name/{name}": {
      "get": {
        "tags": ["Ekadash Info"],
        "summary": "Get by name (path)",
        "description": "Get one ekadash info by name from path (case-insensitive).",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "status and data (single EkadashInfoItem)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashInfoOneResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": {
            "description": "Ekadashi info not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ekadash-info/{id}": {
      "get": {
        "tags": ["Ekadash Info"],
        "summary": "Get by ID",
        "description": "Get one ekadash info by MongoDB ObjectId.",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "status and data (single EkadashInfoItem)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EkadashInfoOneResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": {
            "description": "Ekadashi info not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/city": {
      "get": {
        "tags": ["City"],
        "summary": "Get city by name",
        "description": "Search cities by name or slug (prefix, case-insensitive). Returns up to 20. Query: name=...",
        "security": [{ "ApiKey": [] }, { "Bearer": [] }],
        "parameters": [
          { "name": "name", "in": "query", "required": true, "schema": { "type": "string" }, "description": "City name or slug" }
        ],
        "responses": {
          "200": {
            "description": "Array of city documents (id, name, slug, zone, timestamps)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/City" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal server error" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "success" },
          "message": { "type": "string", "example": "API is running" },
          "time": { "type": "string", "format": "date-time" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "description": "MongoDB ObjectId" },
          "deviceId": { "type": "string" },
          "language": { "type": "string" },
          "timezone": { "type": "string" },
          "email": { "type": "string", "nullable": true },
          "tg": { "type": "string", "nullable": true },
          "daysRemindPush": { "type": "number" },
          "notifiedToday": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "AuthSignUpBody": {
        "type": "object",
        "properties": {
          "deviceId": { "type": "string" },
          "language": { "type": "string" },
          "timezone": { "type": "string" }
        }
      },
      "AuthSignInBody": {
        "type": "object",
        "properties": {
          "deviceId": { "type": "string" }
        }
      },
      "LogsBody": {
        "type": "object",
        "properties": {
          "logMessage": { "type": "array", "items": {}, "description": "Client log entries" }
        }
      },
      "LogsResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "logs published" }
        }
      },
      "UpdateResult": {
        "type": "object",
        "description": "Mongoose updateOne result",
        "properties": {
          "acknowledged": { "type": "boolean" },
          "modifiedCount": { "type": "number" },
          "matchedCount": { "type": "number" }
        }
      },
      "EkadashItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "MongoDB ObjectId" },
          "date": { "type": "string", "example": "2025-01-15", "description": "YYYY-MM-DD" },
          "name": { "type": "string", "description": "Ekadasi name" },
          "exit_time": { "type": "string", "nullable": true }
        }
      },
      "EkadashYearResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "ekadashes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EkadashItem" }
          }
        }
      },
      "EkadashMonthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "ekadashes": {
            "type": "array",
            "items": { "type": "object", "description": "Ekadashi document (year, month, day, ekadasi_name, exit_time, description_data)" }
          }
        }
      },
      "EkadashDayResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "ekadash": {
            "type": "object",
            "description": "Single ekadashi with populated description_data",
            "properties": {
              "year": { "type": "number" },
              "month": { "type": "number" },
              "day": { "type": "number" },
              "ekadasi_name": { "type": "string" },
              "exit_time": { "type": "string" },
              "description_data": { "$ref": "#/components/schemas/EkadashInfoItem" }
            }
          }
        }
      },
      "EkadashInfoItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "name_hi": { "type": "string" },
          "name_ru": { "type": "string" },
          "name_en": { "type": "string" },
          "description_ru": { "type": "string" },
          "description_hi": { "type": "string" },
          "description_en": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "EkadashInfoListResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EkadashInfoItem" }
          }
        }
      },
      "EkadashInfoOneResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/EkadashInfoItem" }
        }
      },
      "City": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "zone": { "type": "number" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": false },
          "message": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Server API key"
      },
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Authorization token (device ID)"
      }
    }
  }
}
